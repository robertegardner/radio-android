<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Streaming + network state -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Media3 foreground playback (targetSdk 34+ rules) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- ExoPlayer setWakeMode(WAKE_MODE_NETWORK) acquires a wake lock to keep
         streaming with the screen off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Reactive audio visualizer (android.media.audiofx.Visualizer) taps the
         audio output and so requires RECORD_AUDIO. Only used if the user picks
         the Reactive visualizer; remove this if we drop that option. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Runtime permission on API 33+ for the media notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".RadioApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Radio">

        <!-- HTTPS only: no usesCleartextTraffic exception (see CLAUDE.md). -->

        <!-- Android Auto media-app declaration. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Radio">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Media3 MediaLibraryService: drives the media session (notification +
          lock-screen transport, promoted to a foreground service while
          playing) and exposes the Android Auto browse tree. The two
          intent-filter actions serve Media3 controllers and the legacy
          MediaBrowser clients (Android Auto) respectively.
        -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

    </application>

</manifest>
