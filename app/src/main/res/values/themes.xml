<resources>
    <!-- Compose drives the UI; this is just the launch/base theme. Dark window
         background avoids a white flash before Compose draws. -->
    <style name="Theme.Radio" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/radio_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
